function iacommit() {
  if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "No estás dentro de un repositorio Git."
    return 1
  fi

  # Obtener cambios staged y no staged
  local changes=$(git diff --staged --no-color && git diff --no-color)

  if [[ -z "$changes" ]]; then
    echo "No hay cambios preparados para commit."
    return 1
  fi

  local prompt="Generate a concise and descriptive commit message the following changes:\n\n$changes"
  local commit_message=$(ask_openai "gpt-4o-mini" "$prompt" 60)

  if [[ -z "$commit_message" || "$commit_message" == "null" ]]; then
    echo "No se pudo generar el mensaje de commit."
    return 1
  fi

  # Mostrar el mensaje de commit y confirmar
  echo "Mensaje de commit generado:"
  echo "$commit_message"
  echo "¿Confirmar el commit? (s/n)"
  read confirm

  if [[ "$confirm" == "s" || "$confirm" == "S" ]]; then
    # Sanitize commit message: remove code fences and unwanted control characters (except newline)
    local clean_message
    clean_message=$(printf "%s\n" "$commit_message" \
      | sed '/^```/d' \
      | tr -d '\000-\011\013-\037')
    # Use a temporary file to handle multi-line messages safely
    local tmpfile
    tmpfile=$(mktemp)
    printf "%s\n" "$clean_message" > "$tmpfile"
    git commit -a -F "$tmpfile"
    rm -f "$tmpfile"
  else
    echo "Commit cancelado."
  fi
}

function ask_openai() {
  local model="$1"
  local prompt="$2"
  local max_tokens="$3"

  if [[ -z "${OPENAI_API_KEY}" ]]; then
    echo "Error: La variable OPENAI_API_KEY no está definida."
    return 1
  fi

  local json_payload
  json_payload=$(printf '%s' "$prompt" | jq -Rs --arg model "$model" --argjson max_tokens "$max_tokens" \
    '{
      model: $model,
      messages: [{role: "user", content: .}],
      max_tokens: $max_tokens
    }')

  local response=$(curl -s -X POST "https://api.openai.com/v1/chat/completions" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${OPENAI_API_KEY}" \
    -d "$json_payload")

  if [[ $(printf '%s' "$response" | jq -r '.error') != "null" ]]; then
    echo "Error en la API de OpenAI:"
    printf '%s' "$response" | jq -r '.error.message'
    return 1
  fi

  printf '%s' "$response" | jq -r '.choices[0].message.content'
}

function fix_wifi() {
  local iface="wlo1"
  local my_ip=$(ip -4 addr show $iface | grep -oP '(?<=inet\s)\d+(\.\d+){3}')
  local current_gw=$(ip route | grep default | awk '{print $3}')

  if [[ -z "$my_ip" || -z "$current_gw" ]]; then
    echo "❌ No se detectó IP o gateway en $iface. ¿Estás conectado?"
    return 1
  fi

  local my_net_prefix="${my_ip%.*}"
  local gw_prefix="${current_gw%.*}"
  local reconnect=false

  echo "📡 IP: $my_ip"
  echo "🌐 Gateway detectado: $current_gw"

  if [[ "$my_net_prefix" != "$gw_prefix" ]]; then
    echo "⚠️ Gateway y red no coinciden. Corrigiendo ruta..."
    sudo ip route del default
    sudo ip route add default via "$my_net_prefix.1" dev "$iface"
    reconnect=true
    echo "✅ Ruta actualizada a $my_net_prefix.1"
  else
    echo "✅ Gateway está en el rango correcto. Probando conectividad..."
    if ping -c 1 -W 1 "$current_gw" > /dev/null; then
      echo "✅ Todo en orden. No se requiere acción."
    else
      echo "⚠️ Gateway $current_gw no responde. Forzando actualización..."
      sudo ip route del default
      sudo ip route add default via "$current_gw" dev "$iface"
      reconnect=true
      echo "✅ Ruta actualizada con el gateway detectado ($current_gw)"
    fi
  fi

  if [[ "$reconnect" == true ]]; then
    echo "🔁 Reiniciando conexión WiFi $iface..."
    nmcli dev disconnect "$iface"
    sleep 2
    nmcli dev connect "$iface"
    echo "✅ Conexión reiniciada."
  fi
}

qa_browser() {
  # Start Chrome with remote DevTools and store port/WS for reuse.
  local port="$1"
  local url="${2:-http://manager.crisalix.local:3000}"
  local user_dir="${3:-$HOME/config/google-chrome}"
  local log_file="/tmp/chrome-remote.log"
  local port_file="${user_dir}/DevToolsActivePort"
  local port_link="$HOME/.config/google-chrome/DevToolsActivePort"

  # Early validation: require chrome binary available.
  if ! command -v google-chrome-stable >/dev/null 2>&1; then
    echo "google-chrome-stable is not installed."
    return 1
  fi

  # Prepare profile/symlink and clear the log before using it.
  mkdir -p "$user_dir"
  mkdir -p "$(dirname "$port_link")"
  if [[ -e "$port_link" ]]; then
    rm -f "$port_link"
  fi
  ln -sfn "$port_file" "$port_link"
  : > "$log_file"

  # If an active DevTools exists, try to reuse its port.
  if [[ -z "$port" && -f "$port_file" ]]; then
    port=$(head -n1 "$port_file" 2>/dev/null | tr -d '\r\n')
  fi

  # Default port when none provided or retrievable.
  if [[ -z "$port" ]]; then
    port=39931
  fi

  # Quick check: DevTools already listening? Reuse and refresh WS info.
  if resp=$(curl -sf "http://localhost:${port}/json/version" 2>/dev/null); then
    local ws_url ws_path
    ws_url=$(printf '%s' "$resp" | tr -d '\n' | sed -n 's/.*"webSocketDebuggerUrl"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
    if [[ -n "$ws_url" ]]; then
      ws_path=$(printf '%s\n' "$ws_url" | sed -E 's#^[^/]*//[^/]+(/.*)#\1#')
      if [[ -n "$ws_path" ]]; then
        printf "%s\n%s\n" "$port" "$ws_path" > "$port_file"
      fi
    fi
    echo "DevTools already responding on localhost:${port}"
    [[ -n "$ws_url" ]] && echo "WS: $ws_url"
    return 0
  fi

  # Launch Chrome with the given profile and configured remote port.
  echo "Starting Chrome with profile ${user_dir} and port ${port}..."
  nohup google-chrome-stable \
    --remote-debugging-port="${port}" \
    --user-data-dir="${user_dir}" \
    --no-first-run \
    --no-default-browser-check \
    --disable-dev-shm-usage \
    --disable-gpu \
    --use-gl=swiftshader \
    --window-size=1280,720 \
    "${url}" >> "${log_file}" 2>&1 &
  local chrome_pid=$!
  disown

  # Poll up to 15s for DevTools, storing WS info when it appears.
  for i in {1..30}; do
    if resp=$(curl -sf "http://localhost:${port}/json/version" 2>/dev/null); then
      local ws_url ws_path
      ws_url=$(printf '%s' "$resp" | tr -d '\n' | sed -n 's/.*"webSocketDebuggerUrl"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
      if [[ -n "$ws_url" ]]; then
        ws_path=$(printf '%s\n' "$ws_url" | sed -E 's#^[^/]*//[^/]+(/.*)#\1#')
        if [[ -n "$ws_path" ]]; then
          printf "%s\n%s\n" "$port" "$ws_path" > "$port_file"
        fi
      fi
      echo "✅ DevTools ready on localhost:${port}"
      [[ -n "$ws_url" ]] && echo "WS: $ws_url"
      return 0
    fi
    sleep 0.5
  done

  # If it never responded, report and leave traces in the log for debugging.
  echo "❌ Chrome started (PID $chrome_pid) but DevTools did not respond. Check ${log_file}"
  return 1
}

