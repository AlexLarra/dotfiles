  pulseaudio -k
  sleep 1
  pulseaudio --start

  echo "🔄 Recargando ALSA (si está disponible)..."
  if command -v sudo >/dev/null && [ -w /etc/modprobe.d ]; then
  sudo alsa force-reload
  fi

